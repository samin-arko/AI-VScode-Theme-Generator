{
    "compilerOptions": {
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2022",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "skipLibCheck": true,
        "types": [
            "node",
            "mocha"
        ],
        "sourceMap": true,
        "rootDir": "src",
        "strict": true
    },
    "include": [
        "src/**/*"
    ]
}